{
  "name": "life-backend",
  "version": "2.0.0",
  "description": "Backend server for Life application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "echo \"Error: no test specified\" && exit 0",
    "setup-admin": "node admin-init.js",
    "reset-db": "rm -f data/life.db && echo 'Database reset. Restart server to reinitialize.'",
    "backup-db": "cp data/life.db data/life.db.backup.$(date +%Y%m%d_%H%M%S) && echo 'Database backed up'",
    "health-check": "curl http://localhost:3000/api/health"
  },
  "keywords": [
    "life",
    "community",
    "backend",
    "api"
  ],
  "author": "Life Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "jwt-simple": "^0.5.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "body-parser": "^1.20.2",
    "uuid": "^9.0.0",
    "socket.io": "^4.6.1"
  }
}
